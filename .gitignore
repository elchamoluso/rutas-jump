# --- Tu configuración y datos personales (NO se publican) ---
rutas.config.sh
rutas.generated.sh
custom-aliases.sh

# Compat: artefactos del sistema antiguo (por si quedan en algún clon)
rutas.sh
mac-rutas.sh
extra-aliases.sh

# --- Artefactos generados (se regeneran; no se versionan) ---
dashboard.html
dashboard.html.tmp
*.tmp
.serve.log

# --- Herramientas / editor ---
.claude/
node_modules/

# --- Bundle React Spectrum prebuild (SÍ se versiona; el runtime node-only depende de él) ---
# node_modules y dist/ están ignorados, pero ui/dashboard.bundle.js es el artefacto
# COMMITEADO que generate-dashboard.js inyecta en cada máquina sin necesidad de npm.
!ui/dashboard.bundle.js

# El ~/.gitignore_global del usuario ignora *.json; forzamos los manifest de build
# (necesarios para que un contribuidor pueda `npm install && npm run build`).
!package.json
!package-lock.json

# --- Backups del instalador ---
*.rutasjump.bak
*.drivejump.bak

